# ─────────────────────────────────────────────────────────────────
# SeducLog — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma and the API container.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://seduclog:change_me@localhost:5432/seduclog

# ── PostgreSQL service (docker-compose only) ──────────────────────
POSTGRES_USER=seduclog
POSTGRES_PASSWORD=change_me
POSTGRES_DB=seduclog

# ── API server ────────────────────────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# TCP port the Node.js API listens on (default: 4000).
PORT=4000

# Allowed CORS origin for the API (set to your frontend URL).
CLIENT_URL=http://localhost

# ── Frontend ──────────────────────────────────────────────────────
# Base URL that the browser uses to reach the API.
# In the Docker setup the nginx proxy rewrites /api/* and /socket.io/*,
# so leave this empty ("") when running behind nginx.
# For local development set it to the API address.
VITE_API_URL=http://localhost:4000
