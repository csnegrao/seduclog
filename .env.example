# ──────────────────────────────────────────────────────────────────
# Seduclog — Environment Variables
# Copy this file to .env and fill in the values before running.
# ──────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ──────────────────────────────────────────
# NOTE: The current backend uses an in-memory store.
# These variables are provided for the docker-compose setup and
# future migration to a persistent Postgres database.
POSTGRES_USER=seduclog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=seduclog

# Full Prisma/pg connection string (used by the API)
DATABASE_URL=postgresql://seduclog:changeme@localhost:5432/seduclog

# ── JWT ───────────────────────────────────────────────────────────
# Use long, random strings in production (e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Token expiry durations (ms/zeit format)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API Server ────────────────────────────────────────────────────
PORT=3001

# Allowed CORS origin for Socket.io (set to frontend URL in production)
FRONTEND_URL=http://localhost:3000

# ── Google Maps (optional) ────────────────────────────────────────
# Provide a valid API key to enable real ETA calculation.
# Without this key the server falls back to no ETA.
GOOGLE_MAPS_API_KEY=

# ── Frontend (React) ─────────────────────────────────────────────
# Set to empty string when using the nginx proxy (docker-compose).
# Set to http://localhost:3001 for local development (npm start).
REACT_APP_API_BASE=http://localhost:3001
# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# MariaDB / MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=seduclog
DB_USERNAME=seduclog_user
DB_PASSWORD=your_password_here
